{
  "principle": "Do not ask every participant or founder for API keys up front. Request credentials progressively only when a selected connector needs them.",
  "credential_classes": [
    {
      "id": "no_secret",
      "examples": [
        "public docs",
        "public hackathon pages",
        "startup libraries",
        "skill packs"
      ],
      "mvp_status": "enable_by_default"
    },
    {
      "id": "api_key_or_pat",
      "examples": [
        "GitHub",
        "Kaggle",
        "Hugging Face",
        "Colosseum Copilot",
        "NASA APIs"
      ],
      "mvp_status": "progressive_connection"
    },
    {
      "id": "oauth_or_service_principal",
      "examples": [
        "GitHub App",
        "Vercel OAuth",
        "Azure Entra",
        "Google Cloud service account",
        "AWS IAM role"
      ],
      "mvp_status": "team_or_org_connector"
    },
    {
      "id": "paid_api",
      "examples": [
        "OpenAI",
        "Gemini",
        "Anthropic",
        "ElevenLabs",
        "cloud credits"
      ],
      "mvp_status": "platform_owned_first_byok_optional"
    },
    {
      "id": "wallet_private_key_or_mnemonic",
      "examples": [
        "Solana Agent Kit",
        "Coinbase AgentKit",
        "BNBChain MCP write actions",
        "deploy wallets"
      ],
      "mvp_status": "defer_until_permission_gates"
    }
  ],
  "owners": [
    "user",
    "team",
    "organization",
    "platform",
    "local_open_source"
  ],
  "safety_rule": "Wallet/private-key tools are not normal API connectors. Default to devnet/read-only and require explicit approval, audit logs, spending limits, and throwaway wallets."
}
