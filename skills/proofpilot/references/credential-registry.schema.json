{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofpilot.dev/schemas/credential-registry.schema.json",
  "title": "ProofPilot credential registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "owners", "permission_classes", "credential_classes", "prohibited_inputs"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "owners": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "permission_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "description": { "$ref": "#/$defs/text" }
        }
      }
    },
    "credential_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "risk", "default_behavior", "storage_policy"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "label": { "$ref": "#/$defs/text" },
          "risk": { "enum": ["low", "medium", "high", "critical"] },
          "default_behavior": { "$ref": "#/$defs/text" },
          "storage_policy": { "$ref": "#/$defs/text" }
        }
      }
    },
    "prohibited_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "text": { "type": "string", "minLength": 1 }
  }
}
